# =============================================================================
# Mensa — Production / subscriber web-server deployment
# =============================================================================
# Copy to .env on your server:
#   cp .env.production.example .env
#
# Deploy:
#   ./scripts/deploy-production.sh
# =============================================================================

# --- Public site (required for HTTPS) ---
DOMAIN=mensa.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Caddy config: tls | subscribers | ip
#   tls         = HTTPS, public app (no login)
#   subscribers = HTTPS + HTTP basic auth (paying customers)
#   ip          = HTTP only on port 80 (LAN or external TLS proxy)
CADDY_PROFILE=tls

# --- Subscriber basic auth (only when CADDY_PROFILE=subscribers) ---
# Generate hash:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'change-me'
BASIC_AUTH_USER=subscriber
BASIC_AUTH_HASH=

# --- Container images (pin a release tag in production) ---
MENSA_REGISTRY=ghcr.io/adportfolionode
MENSA_VERSION=latest

# Build on server instead of pulling GHCR (set to 1 if registry is private)
# BUILD_LOCAL=1

# --- CORS (set to your public URL; leave empty to allow same-origin only via nginx) ---
CORS_ALLOWED_ORIGINS=https://mensa.yourdomain.com

# --- AI keys (server-side; subscribers never see these) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
CHAT_GPT_API_KEY=
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-3-mini-beta

# --- Resources ---
BACKEND_MEMORY_LIMIT=6G

# --- Direct HTTP mode (docker-compose.direct.yml, no Caddy) ---
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=3000

# --- Training defaults (optional overrides) ---
# TRAIN_TARGET_ACCURACY=0.90
# TRAIN_MAX_ATTEMPTS=40