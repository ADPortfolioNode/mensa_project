+  // Fetch recommended training settings when user selects a game to train.
+  // Preserve user edits: only overwrite if current params still match the
+  // previously loaded defaults (or no defaults were loaded yet).
+  useEffect(() => {
+    if (!selectedTrainGame) return;
+    let cancelled = false;
+
+    const mappedDefaultsFrom = (defaults, prev) => ({
+      testSize: defaults.train_size ?? (prev?.testSize ?? 0.33),
+      randomState: defaults.random_state ?? (prev?.randomState ?? 42),
+      nEstimators: defaults.n_estimators ?? (prev?.nEstimators ?? 100),
+      maxDepth: defaults.max_depth ?? (prev?.maxDepth ?? 10),
+      targetAccuracy: defaults.target_accuracy ?? (prev?.targetAccuracy),
+    });
+
+    const shallowEqual = (a, b, keys) => {
+      if (!a || !b) return false;
+      for (const k of keys) {
+        if ((a[k] ?? null) !== (b[k] ?? null)) return false;
+      }
+      return true;
+    };
+
+    const fetchSettings = async () => {
+      try {
+        const url = `${API_BASE}/api/train_settings?game=${selectedTrainGame}`;
+        const r = await axios.get(url);
+        if (cancelled || !r?.data) return;
+        const defaults = r.data.defaults || {};
+        const mapped = mappedDefaultsFrom(defaults, trainParams);
+        const keys = ['testSize', 'randomState', 'nEstimators', 'maxDepth'];
+
+        const baseline = trainDefaultsForGame;
+        const current = trainParams;
+
+        // Overwrite only if user hasn't modified params (current equals baseline)
+        const shouldOverwrite = baseline === null || shallowEqual(current, baseline, keys);
+
+        if (shouldOverwrite) {
+          setTrainParams((prev) => ({ ...prev, ...mapped }));
+        }
+
+        // Update baseline to latest defaults for future comparisons
+        setTrainDefaultsForGame(mapped);
+      } catch (err) {
+        // ignore transient failures — keep existing params
+      }
+    };
+
+    fetchSettings();
+    return () => { cancelled = true; };
+  }, [selectedTrainGame, API_BASE, trainDefaultsForGame, trainParams]);
