# Example environment variables for local development and Docker
# Copy this file to .env and fill in your actual values

# Frontend Environment Variables (React)
# Public base URL for the backend API. Example values:
# - Local dev: http://localhost:5000
# - Production: https://api.example.com
REACT_APP_API_BASE=http://localhost:5000

# Backend Environment Variables (Python/FastAPI)
# Data directory for persistent storage
DATA_DIR=/data

# API Keys (Required for RAG functionality)
GEMINI_API_KEY=your_gemini_api_key_here
CHAT_GPT_API_KEY=your_chatgpt_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROK_API_KEY=your_grok_api_key_here

# Grok API Configuration
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-3-mini-beta

# ChromaDB Configuration
CHROMA_HOST=mensa_chroma
CHROMA_PORT=8000
CHROMA_SDK_ENABLED=1

# Ingest Configuration
MAX_CONCURRENT_CLONES=3
INGEST_BATCH_SIZE=4000
INGEST_REQUEST_TIMEOUT=20
INGEST_MAX_RETRIES=2
INGEST_RETRY_DELAY=1
INGEST_ENABLE_CATALOG_FALLBACK=0
INGEST_MAX_CATALOG_CANDIDATES=3

# Docker Build Configuration
BACKEND_CACHE_BUSTER=stable
