# =============================================================================
# Mensa Project - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NOTE: Never commit the actual .env file to git. It contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# API Keys (Required for AI features)
# ---------------------------------------------------------------------------
# Get these from their respective providers:
#   Gemini:   https://aistudio.google.com/app/apikey
#   OpenAI:   https://platform.openai.com/api-keys
#   Grok:     https://console.x.ai
#
# At least ONE API key must be set for the chat/concierge features to work.
# Leave blank to disable that provider.

# Google Gemini
GEMINI_API_KEY=

# OpenAI / ChatGPT
OPENAI_API_KEY=
CHAT_GPT_API_KEY=

# xAI Grok
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-3-mini-beta

# ---------------------------------------------------------------------------
# Backend Configuration
# ---------------------------------------------------------------------------

# Data directory (mounted volume path inside container)
DATA_DIR=/data

# ChromaDB connection (container-internal; do not change unless chroma image changes)
CHROMA_HOST=mensa_chroma
CHROMA_PORT=8000
CHROMA_SDK_ENABLED=1

# Training defaults (backend)
# TRAIN_TARGET_ACCURACY=0.90
# TRAIN_MAX_ATTEMPTS=40
# TRAIN_SIZE=0.25
# TRAIN_N_ESTIMATORS=250
# TRAIN_MAX_DEPTH=18
# TRAIN_RANDOM_STATE=42
# TRAIN_BLEND_STEP=0.05
# TRAIN_DATA_LIMIT=0

# Docker host port mappings (only needed when defaults are taken by other apps)
# BACKEND_HOST_PORT=5000
# CHROMA_HOST_PORT=8000
# Windows: bind published ports to IPv4 loopback (avoids localhost/wslrelay conflicts)
DOCKER_BIND_HOST=127.0.0.1
# FRONTEND_HOST_PORT=3000

# Ingestion settings
MAX_CONCURRENT_CLONES=3
INGEST_BATCH_SIZE=6000
INGEST_REQUEST_TIMEOUT=30
INGEST_MAX_RETRIES=3
INGEST_RETRY_DELAY=1
INGEST_BATCH_MAX_RETRIES=2
INGEST_PROGRESS_INTERVAL_S=0.5
INGEST_STATE_SAVE_INTERVAL_S=2
INGEST_STARTUP_COUNT_WORKERS=4
INGEST_STARTUP_PARALLEL=1
INGEST_ENABLE_CATALOG_FALLBACK=0
INGEST_MAX_CATALOG_CANDIDATES=3
INGEST_SKIP_FETCH_THRESHOLD=50000
INGEST_FAST_COMPLETE_POPULATED=1

# ---------------------------------------------------------------------------
# Docker Build
# ---------------------------------------------------------------------------
# Set a unique value to force a rebuild of the backend image (cache busting)
# BACKEND_CACHE_BUSTER=$(date +%s)

# ---------------------------------------------------------------------------
# Frontend Configuration
# ---------------------------------------------------------------------------

# Backend API URL that the frontend will call
# In Docker Compose: http://backend:5000
# For local dev:     http://localhost:5000
# For production:    https://your-backend-domain.com
REACT_APP_API_BASE=http://localhost:5000

# Frontend build settings (for Create React App)
CHOKIDAR_USEPOLLING=true
DISABLE_ESLINT_PLUGIN=true
ESLINT_NO_DEV_ERRORS=true
TSC_COMPILE_ON_ERROR=true

# Frontend environment variable for Docker
HOME=/app

# ---------------------------------------------------------------------------
# Vercel / Deployment (Optional)
# ---------------------------------------------------------------------------
# Used by the frontend when deployed to Vercel. Set in Vercel dashboard.
# VERCEL_URL=
