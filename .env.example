# Example environment variables for local development and Vercel
# For Create React App these are injected at build time and must be prefixed with REACT_APP_

# Public base URL for the backend API. Example values:
# - Local dev: http://localhost:5000
# - Production: https://api.example.com
REACT_APP_API_BASE=http://localhost:5000

# Add other non-secret variables here as needed.
