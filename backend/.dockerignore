# Git
.git
.gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
venv/

# Environment variables - CRITICAL: Never include secrets in Docker images
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Secrets and credentials
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
*.secret
*secret*

# API keys and tokens (pattern matching)
*api_key*
*apikey*
*api-key*
*token*
*secret*

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Data - mounted as a volume, should not be in build context
data/

# Logs with potential sensitive data
*.log
logs/
diag_*.log
startup_*.log
*_output.log
*_exit.log

# Database files with potential sensitive data
*.db
*.sqlite
*.sqlite3
